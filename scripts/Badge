const { Client, GatewayIntentBits, REST, Routes, SlashCommandBuilder } = require('discord.js');

const TOKEN = 'MTQ4NzgwNTU0NTQzMDkwODk1OA.GJTghi.4W8SKfngBDfqvjeR8tDFF6DdfjeLUQte9Jsmv8';
const CLIENT_ID = 'YOUR_CLIENT_I1487805545430908958D';
const GUILD_ID = '1415322587503919266';

const client = new Client({ intents: [GatewayIntentBits.Guilds] });

const commands = [
  new SlashCommandBuilder()
    .setName('badge')
    .setDescription('Command for Active Developer Badge')
].map(command => command.toJSON());

const rest = new REST({ version: '10' }).setToken(TOKEN);

(async () => {
  try {
    console.log('Registering slash command...');
    await rest.put(
      Routes.applicationGuildCommands(CLIENT_ID, GUILD_ID),
      { body: commands },
    );
    console.log('Slash command registered.');
  } catch (error) {
    console.error(error);
  }
})();

client.on('ready', () => {
  console.log(`Logged in as ${client.user.tag}`);
});

client.on('interactionCreate', async interaction => {
  if (!interaction.isChatInputCommand()) return;

  if (interaction.commandName === 'badge') {
    await interaction.reply('Active Developer Badge Command Executed ✅');
  }
});

client.login(TOKEN);
